# Copy this file to .env.local and fill in values from your Supabase project
# settings (Project Settings > API). Never commit the real .env.local file.
#
# Use the "Publishable key" (sb_publishable_...), not the legacy "anon" key.
# Supabase is retiring legacy anon/service_role keys in late 2026; the
# publishable key is a drop-in replacement with the same low-privilege
# behavior (createClient() accepts either), so there's no reason to start
# a new project on the key type that's being phased out.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-publishable-key
